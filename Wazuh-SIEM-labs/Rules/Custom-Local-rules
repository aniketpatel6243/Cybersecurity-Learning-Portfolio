
<!-- Custom Detection Rules - Wazuh Home Lab -->
<!-- Author : Aniket Patel -->

<group name="custom_security_rules,">

<!-- Rule1: SSH Brute Force Detection-->
  <rule id="100001" level="10" frequency="5" timeframe="120">
    <if_matched_sid>5760</if_matched_sid>
    <same_source_ip />
    <description>Custom : SSH Brute Force Attack detected from $(srcip)</description>
    <mitre>
      <id>T1110</id>
    </mitre>
    <group>authentication_failures,brute_force,</group>
  </rule>

<!-- Rule2 : File Integrity - Critical File Modified -->
  <rule id="100002" level="12">
    <if_sid>550</if_sid>
    <match>/etc/passwd</match>
    <description>Custom: Critical File /etc/passwd was modified </description>
    <mitre>
      <id>T1078</id>
    </mitre>
    <group>fim,critical_file_change,</group>
  </rule>

<!-- Rule3 : Privilege Escalation -Failed Sudo -->
  <rule id="100003" level="10" frequency="3" timeframe="60">
    <if_matched_sid>5402</if_matched_sid>
    <description>Custom : Multiple failed sudo attempts by $(srcuser)</description>
    <mitre>
      <id>T1548</id>
    </mitre>
    <group>privilege_escalation,sudo_abuse,</group>
  </rule>

</group>
